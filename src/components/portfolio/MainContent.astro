---
// components/portfolio/MainContent.astro
import { Image } from "astro:assets";
import {
  NextjsIcon,
  TypeScriptIcon,
  TailwindIcon,
  AstroIcon,
  BunIcon,
} from "../icons/icons.tsx";
import { Linkedin, Twitter, Quote } from "lucide-react";
import { GithubLogo } from "@phosphor-icons/react";
import NameBanner from "./NameBanner.astro";
import ToolboxBanner from "./ToolboxBanner.astro";
import DineshPdf from "../../assets/Dinesh.pdf";

import project1Image from "../../assets/images/project-1.png";
import project2Image from "../../assets/images/project-2.png";
import project3Image from "../../assets/images/project-3.png";
import project4Image from "../../assets/images/project-4.png";

// --- DATA ---
const TOOLBOX_ITEMS = [
  {
    id: "nextjs",
    name: "Next.js",
    component: NextjsIcon,
    category: "Full-Stack Framework",
    description:
      "My go-to for building high-performance, production-ready web applications. The combination of Server Components, static generation, and a first-class developer experience makes it incredibly powerful.",
    link: "https://nextjs.org",
  },
  {
    id: "typescript",
    name: "TypeScript",
    component: TypeScriptIcon,
    category: "Language Superset",
    description:
      "Essential for any large-scale project. The static typing saves countless hours of debugging, improves code maintainability, and enables robust tooling and autocompletion that I can't live without.",
    link: "https://www.typescriptlang.org",
  },
  {
    id: "bun",
    name: "Bun",
    component: BunIcon,
    category: "JavaScript Runtime & Toolkit",
    description:
      "An incredibly fast all-in-one toolkit that has streamlined my workflow. Its speed as a runtime, bundler, and package manager makes development faster and more efficient.",
    link: "https://bun.sh",
  },
  {
    id: "astro",
    name: "Astro",
    component: AstroIcon,
    category: "Web Framework",
    description:
      "Unbeatable for content-focused websites. Astro's island architecture delivers incredible performance by default, shipping zero JavaScript unless explicitly needed. It's a joy to build with.",
    link: "https://astro.build",
  },
  {
    id: "tailwind",
    name: "Tailwind",
    component: TailwindIcon,
    category: "CSS Framework",
    description:
      "A utility-first approach that has completely changed how I write CSS. It allows for rapid prototyping and building complex, custom designs without ever leaving my HTML. It's maintainable and scalable.",
    link: "https://tailwindcss.com",
  },
];

const PROJECTS = [
  {
    name: "Nexseed",
    description: "Next.js app generator with auth & database integration.",
    link: "https://nexseed-docs.vercel.app/",
    tech: ["Next.js", "TypeScript", "Tailwind CSS", "Auth.js"],
    image: project1Image,
    github: "https://github.com/kdinesh24/Nexseed",
  },
  {
    name: "Imaverter",
    description:
      "An intuitive image processing tool for conversion & compression.",
    link: "https://imaverter.vercel.app/",
    tech: ["Next.js", "Typescript", "Tailwind CSS", "Bun"],
    image: project2Image,
    github: "https://github.com/armancurr/imaverter",
  },
  {
    name: "T1Chat",
    description: "AI-powered chatbot with modern interface and real-time responses.",
    link: "https://t1chat.vercel.app/",
    tech: ["Next.js", "TypeScript", "Tailwind CSS", "AI/ML"],
    image: project3Image,
    github: "https://github.com/kdinesh24/t1.chat.git",
  },
  {
    name: "BetterNote",
    description: "A notes app with better UI for seamless note-taking experience.",
    link: "#",
    tech: ["Next.js", "TypeScript", "PostgreSQL", "Drizzle ORM"],
    image: project4Image,
    github: "#",
  },
];
---

<main class="relative min-h-screen bg-background text-foreground font-sans px-4">
  <!-- Grid Background -->
  <div
    class="absolute inset-0 -z-10 h-full w-full bg-background bg-[radial-gradient(#1F2937_1px,transparent_1px)] [background-size:32px_32px]"
  ></div>

  <div class="max-w-3xl mx-auto py-24 md:py-32">
    <!-- Hero Section -->
    <section class="mb-16 animate-fade-in-up">
      <div
        class="inline-flex items-center gap-2.5 border border-border rounded-full px-3 py-1 mb-8 text-sm text-muted-foreground"
      >
        <div
          class="w-2 h-2 bg-green-400 rounded-full animate-pulse"
          style="animation-duration: 2s;"
        ></div>
        Available for new opportunities
      </div>

      <p class="text-lg text-muted-foreground mb-2 pb-3">Hey, I'm</p>
      <div class="pb-3">
        <NameBanner />
      </div>
      <p class="max-w-2xl text-lg text-muted-foreground mb-8">
        Full Stack Developer crafting minimal, functional interfaces with clean
        code. Based in Punjab, India.
      </p>

      <div class="flex items-center gap-6">
        <div class="flex items-center gap-4">
          <a
            href="https://github.com/kdinesh24"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub profile"
            class="text-muted-foreground hover:text-foreground transition-colors"
          >
            <GithubLogo size={26} weight="regular" />
          </a>
          <a
            href="https://linkedin.com/in/kdinesh24"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn profile"
            class="text-muted-foreground hover:text-foreground transition-colors"
          >
            <Linkedin class="w-6 h-6" />
          </a>
          <a
            href="https://twitter.com/K24Dinesh"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X (Twitter) profile"
            class="text-muted-foreground hover:text-foreground transition-colors"
          >
            <Twitter class="w-6 h-6" />
          </a>
        </div>
        <a
          href={DineshPdf}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
        > 
          <span>View Resume</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4 ml-1.5 group-hover:translate-x-1 transition-transform"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    </section>

    <!-- About Section -->
    <section class="mb-24 animate-fade-in-up [animation-delay:200ms]">
      <h2 class="text-xl font-semibold tracking-tight mb-6">About</h2>
      <div class="space-y-6 text-muted-foreground text-base leading-relaxed">
        <p>
          I specialize in building exceptional digital products that live at the
          intersection of design and technology. With a passion for modern web
          standards and a keen eye for detail, I focus on creating seamless user
          experiences through clean, efficient, and maintainable code.
        </p>
      </div>
    </section>

    <!-- Interactive Developer Toolbox Section -->
    <section class="mb-24 animate-fade-in-up [animation-delay:300ms]">
      <h2 class="text-xl font-semibold tracking-tight mb-6">
        The Developer's Toolbox
      </h2>
      <div class="flex flex-col md:flex-row gap-6">
        <!-- Tool Selector -->
        <div class="grid grid-cols-5 md:grid-cols-1 gap-4" id="toolbox-selector">
          {
            TOOLBOX_ITEMS.map((tool, index) => {
              const IconComponent = tool.component;
              return (
                <button
                  data-tool={tool.id}
                  class={`toolbox-item group flex items-center justify-center p-4 rounded-lg transition-all duration-300 ${
                    index === 0 ? "toolbox-active" : ""
                  }`}
                >
                  <IconComponent class="h-8 w-8" />
                </button>
              );
            })
          }
        </div>

        <!-- Tool Details Display -->
        <div
          class="flex-1 flex flex-col bg-muted/5 hover:bg-muted/10 transition-all duration-500 p-6 rounded-lg border border-border"
          id="toolbox-display"
        >
          <div class="flex-grow">
            <!-- Dynamic Banner Container -->
            <div id="banner-container">
              {
                TOOLBOX_ITEMS.map((tool, index) => (
                  <div
                    data-tool-banner={tool.id}
                    class={index !== 0 ? "hidden" : ""}
                  >
                    <ToolboxBanner toolId={tool.id} />
                  </div>
                ))
              }
            </div>
            <p
              id="tool-category"
              class="text-base text-muted-foreground mt-6 mb-6"
            >
              Full-Stack Framework
            </p>
            <p id="tool-description" class="text-base leading-relaxed">
              My go-to for building high-performance, production-ready web
              applications. The combination of Server Components, static
              generation, and a first-class developer experience makes it
              incredibly powerful.
            </p>
          </div>
          <a
            id="tool-link"
            href="https://nextjs.org"
            target="_blank"
            rel="noopener noreferrer"
            class="group mt-auto pt-4 inline-flex items-center text-sm font-medium text-foreground hover:text-muted-foreground"
          >
            <span>Visit website</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-4 h-4 ml-1.5 group-hover:translate-x-1 transition-transform"
            >
              <path d="M7 7h10v10" />
              <path d="M7 17 17 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section class="mb-24 animate-fade-in-up [animation-delay:400ms]" id="projects-section">
      <h2 class="text-xl font-semibold tracking-tight mb-6">Projects</h2>
      <div class="relative -ml-4 md:-ml-4 -ml-2">
        <!-- Main border line -->
        <div class="absolute left-0 top-4 w-0.5 h-full bg-border timeline-line"></div>
        
        <ul class="flex flex-col">
          {
            PROJECTS.map((project, index) => (
              <li class="relative">
                <!-- Animated Line -->
                {index < PROJECTS.length - 1 && (
                  <div 
                    class={`absolute left-0 w-0.5 bg-white/80 project-line-grow-${index} timeline-animated-line`}
                    style="top: 16px; height: calc(100% - 16px);"
                  />
                )}
                
                <div class="pl-12 py-4">
                  <div
                    class={`absolute left-0 top-4 w-2.5 h-2.5 bg-muted-foreground rounded-full border-2 border-background project-dot-glow-${index} timeline-dot`}
                  />
                  
                  <!-- Project Content -->
                  <div class="flex flex-col lg:flex-row gap-6">
                    <!-- Project Details -->
                    <div class="flex-1">
                      <div class="mb-1.5">
                        <h3 class="font-medium text-foreground">{project.name}</h3>
                      </div>
                      <p class="text-muted-foreground text-sm leading-relaxed max-w-xl mb-4">
                        {project.description}
                      </p>
                      <div class="flex flex-wrap items-center gap-2 mb-4">
                        {project.tech.map((tech) => (
                          <span class="text-xs font-mono text-muted-foreground bg-muted/60 border border-border rounded-md px-2 py-1">
                            {tech}
                          </span>
                        ))}
                      </div>
                      <div class="flex items-center text-sm font-medium text-muted-foreground">
                        <a
                          href={project.github}
                          target="_blank"
                          rel="noopener noreferrer"
                          aria-label={`View ${project.name} on GitHub`}
                          class="inline-flex items-center gap-1.5 text-muted-foreground hover:text-foreground transition-colors"
                        >
                          <GithubLogo size={16} weight="regular" />
                          <span>GitHub</span>
                        </a>
                      </div>
                    </div>
                    
                    <!-- Project Image -->
                    <div class="w-full lg:w-64 xl:w-72">
                      <a
                        href={project.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="project-image-container group block overflow-hidden rounded-lg border border-border bg-muted/10 transition-all duration-300 relative"
                        aria-label={`Visit ${project.name} live site`}
                      >
                        <div class="rotating-border"></div>
                        <div class="top-shine"></div>
                        <div class="relative aspect-video overflow-hidden">
                          <Image
                            src={project.image}
                            alt={`Screenshot of ${project.name} project`}
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                            loading="lazy"
                            width={400}
                            height={225}
                          />
                        </div>
                      </a>
                    </div>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- Developer Philosophy Section -->
    <section class="mb-24 animate-fade-in-up [animation-delay:450ms]">
      <h2 class="text-xl font-semibold tracking-tight mb-6">Developer Philosophy</h2>
      <div class="relative">
        <div class="philosophy-container relative border border-border rounded-lg p-8 bg-muted/5 hover:bg-muted/10 transition-all duration-500 min-h-[140px] flex items-center justify-center">
          <div class="absolute top-4 left-4 opacity-20">
            <Quote class="w-8 h-8 text-muted-foreground" />
          </div>
          <div class="text-center relative z-10">
            <p class="text-lg leading-relaxed text-foreground font-medium mb-4 animate-fade-in">
              Code with intention. Design with empathy. Build with purpose.
            </p>
          </div>
          <div class="absolute bottom-4 right-4 opacity-20 rotate-180">
            <Quote class="w-8 h-8 text-muted-foreground" />
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="pt-12 border-t border-border animate-fade-in-up [animation-delay:600ms]">
      <p class="text-sm text-muted-foreground text-center">
        © {new Date().getFullYear()} Dinesh. Designed with care in Punjab, India.
      </p>
    </footer>
  </div>
</main>

<script define:vars={{ TOOLBOX_ITEMS, PROJECTS }}>
  document.addEventListener("DOMContentLoaded", () => {
    const selector = document.getElementById("toolbox-selector");
    const bannerContainer = document.getElementById("banner-container");
    const toolCategory = document.getElementById("tool-category");
    const toolDescription = document.getElementById("tool-description");
    const toolLink = document.getElementById("tool-link");

    if (selector && bannerContainer) {
      const banners = bannerContainer.querySelectorAll("[data-tool-banner]");

      selector.addEventListener("click", (e) => {
        const button = e.target.closest("button");
        if (!button) return;

        const toolId = button.dataset.tool;
        const toolData = TOOLBOX_ITEMS.find((t) => t.id === toolId);
        if (!toolData) return;

        // Update content
        toolCategory.textContent = toolData.category;
        toolDescription.textContent = toolData.description;
        toolLink.href = toolData.link;

        // Update active banner
        banners.forEach((banner) => {
          if (banner.dataset.toolBanner === toolId) {
            banner.classList.remove("hidden");
          } else {
            banner.classList.add("hidden");
          }
        });

        // Update active button state
        selector.querySelectorAll("button").forEach((item) => {
          item.classList.remove("toolbox-active");
        });
        button.classList.add("toolbox-active");
      });
    }
  });
</script>
