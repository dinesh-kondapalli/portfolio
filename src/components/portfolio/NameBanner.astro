---
// src/components/portfolio/NameBanner.astro
// This component contains the hand-crafted, pixel-art style SVG for the name "Dinesh".
---

<div class="name-banner-container" aria-hidden="true">
    <svg viewBox="0 0 230 50" class="name-banner-svg">
      <g>
        {/* D */}
        <rect x="0" y="0" width="10" height="50" />
        <rect x="10" y="0" width="20" height="10" />
        <rect x="30" y="10" width="10" height="30" />
        <rect x="10" y="40" width="20" height="10" />
        {/* I */}
        <rect x="50" y="0" width="10" height="50" />
        {/* N */}
        <rect x="70" y="0" width="10" height="50" />
        <rect x="80" y="10" width="10" height="10" />
        <rect x="90" y="20" width="10" height="10" />
        <rect x="100" y="0" width="10" height="50" />
        {/* E */}
        <rect x="120" y="0" width="10" height="50" />
        <rect x="130" y="0" width="20" height="10" />
        <rect x="130" y="20" width="10" height="10" />
        <rect x="130" y="40" width="20" height="10" />
        {/* S */}
        <rect x="160" y="0" width="30" height="10" />
        <rect x="160" y="10" width="10" height="10" />
        <rect x="160" y="20" width="30" height="10" />
        <rect x="180" y="30" width="10" height="10" />
        <rect x="160" y="40" width="30" height="10" />
        {/* H */}
        <rect x="200" y="0" width="10" height="50" />
        <rect x="220" y="0" width="10" height="50" />
        <rect x="200" y="20" width="30" height="10" />
      </g>
    </svg>
  </div>
  
  <style>
    .name-banner-container {
      height: 3rem; /* 48px */
    }
    @media (min-width: 768px) {
      .name-banner-container {
        height: 4rem; /* 64px */
      }
    }
    .name-banner-svg {
      height: 100%;
      width: auto;
      fill: white;
    }
  </style>