---
// src/layouts/Layout.astro
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Dinesh - Software Developer crafting exceptional digital experiences"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Removed Google Fonts, Added Vercel's Geist Fonts -->
    <link
      rel="stylesheet"
      href="https://assets.vercel.com/raw/upload/v1587415301/fonts/geist-sans/geist-sans.css"
    />
    <link
      rel="stylesheet"
      href="https://assets.vercel.com/raw/upload/v1587415301/fonts/geist-mono/geist-mono.css"
    />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      /* Updated font-family declarations to use Geist */
      html {
        font-family: "Geist Sans", -apple-system, BlinkMacSystemFont,
          "Segoe UI", Roboto, sans-serif;
        scroll-behavior: smooth;
        font-feature-settings: "cv02", "cv03", "cv04", "cv11";
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
    </style>
  </head>
  <body class="bg-background text-foreground antialiased">
    <slot />
  </body>
</html>